<Window x:Class="MusicPlayer.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="350" Height="140"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="#1f2b47" Foreground="#e0e0e0">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Text="请输入:" Margin="0,0,0,8"
                   Foreground="#e0e0e0" FontSize="13"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="InputBox" Margin="0,0,8,0"
                     Background="#2a2a4a" Foreground="#e0e0e0"
                     BorderThickness="1" BorderBrush="#3a3f5c"
                     Padding="6,4"/>
            <Button Grid.Column="1" Content="确定" Click="Ok_Click"
                    Background="#e94560" Foreground="White"
                    BorderThickness="0" Padding="14,4" Margin="0,0,6,0"
                    IsDefault="True"/>
            <Button Grid.Column="2" Content="取消" Click="Cancel_Click"
                    Background="#3a3f5c" Foreground="#e0e0e0"
                    BorderThickness="0" Padding="14,4"/>
        </Grid>
    </Grid>
</Window>
