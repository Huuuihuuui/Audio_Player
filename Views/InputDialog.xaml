<!-- 通用文本输入对话框：顶部红色强调条 + 提示文字 + 输入框 + 确定/取消按钮。
     代码后置暴露 Result 属性，用于新建/重命名歌单等场景 -->
<Window x:Class="MusicPlayer.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入" Width="350" Height="140"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource BrushBgCard}"
        Foreground="{StaticResource BrushTextPrimary}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- 顶部红色强调条（3px） -->
        <Border Height="3" Background="{StaticResource BrushAccent}"/>
        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 提示文字 -->
            <TextBlock x:Name="PromptText" Text="请输入:" Margin="0,0,0,8"
                       Foreground="{StaticResource BrushTextPrimary}" FontSize="13"/>

            <!-- 输入行：文本框 + 确定/取消 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="InputBox" Margin="0,0,8,0"
                         Background="{StaticResource BrushBorder}"
                         Foreground="{StaticResource BrushTextPrimary}"
                         BorderThickness="1" BorderBrush="{StaticResource BrushButtonBg}"
                         Padding="6,4"/>
                <Button Grid.Column="1" Content="确定" Click="Ok_Click"
                        Background="{StaticResource BrushAccent}" Foreground="White"
                        Padding="14,4" Margin="0,0,6,0"
                        IsDefault="True"/>
                <Button Grid.Column="2" Content="取消" Click="Cancel_Click"
                        Padding="14,4"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
