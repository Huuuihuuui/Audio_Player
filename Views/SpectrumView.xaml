<!-- 频谱可视化控件：暗色底 + 64柱 StackPanel。
     代码后置 SpectrumView.xaml.cs 动态创建柱子并做 EMA 平滑 + 多色渐变 -->
<UserControl x:Class="MusicPlayer.Views.SpectrumView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="80" Background="Transparent">
    <Grid>
        <!-- 暗色背景 -->
        <Border Background="{StaticResource BrushDarkWell}" CornerRadius="6"/>

        <!-- 频谱柱容器：水平排列，底部对齐，由 C# 代码动态填充 64 个 Rectangle -->
        <StackPanel x:Name="BarsPanel" Orientation="Horizontal"
                    VerticalAlignment="Bottom" Margin="2,0"/>
    </Grid>
</UserControl>
