<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:helpers="clr-namespace:MusicPlayer.Helpers"
                    xmlns:views="clr-namespace:MusicPlayer.Views">

    <!--
        集中式主题资源字典 —— 所有颜色、阴影、渐变、全局样式、转换器均在此定义。
        由 App.xaml 的 MergedDictionaries 引入，修改此文件即可全局换肤。
    -->

    <!-- ============================================================ -->
    <!-- 现代极简白色主题画刷 -->
    <!-- ============================================================ -->
    <SolidColorBrush x:Key="BrushBgPrimary" Color="#FFFFFF"/>       <!-- 主背景：纯白 -->
    <SolidColorBrush x:Key="BrushBgSecondary" Color="#9e9e9e"/>     <!-- 侧栏/次要背景：苹果风浅灰 -->
    <SolidColorBrush x:Key="BrushBgCard" Color="#FFFFFF"/>          <!-- 卡片：纯白 -->
    <SolidColorBrush x:Key="BrushDarkWell" Color="#F0F0F3"/>        <!-- 频谱/嵌入槽：浅凹陷色 -->
    <SolidColorBrush x:Key="BrushAccent" Color="#424242"/>          <!-- 强调色 也用灰色了 -->
    
    <SolidColorBrush x:Key="BrushTextPrimary" Color="#1D1D1F"/>     <!-- 主要文字：接近黑的深灰 -->
    <SolidColorBrush x:Key="BrushTextSecondary" Color="#86868B"/>   <!-- 次要文字：中灰 -->
    <SolidColorBrush x:Key="BrushTextTertiary" Color="#A1A1A6"/>    <!-- 标签文字：浅灰 -->
    
    <SolidColorBrush x:Key="BrushBorder" Color="#E5E5E7"/>          <!-- 分割线：极淡的灰色 -->
    <SolidColorBrush x:Key="BrushButtonBg" Color="#ECECED"/>        <!-- 按钮默认色 -->
    <SolidColorBrush x:Key="BrushHover" Color="#11000008"/>         <!-- 悬停 透明度大-->
    <SolidColorBrush x:Key="BrushSelection" Color="#22000008"/>     <!-- 选中 透明度变小 -->
    <SolidColorBrush x:Key="BrushActive" Color="#007AFF20"/>        <!-- 当前播放高亮 -->

    <!-- ============================================================ -->
    <!-- 播放队列面板专用笔刷（颜色自行填充） -->
    <!-- ============================================================ -->
    <SolidColorBrush x:Key="BrushQueuePanelBg" Color="#d0d0d0"/>          <!-- 队列面板背景 -->
    <SolidColorBrush x:Key="BrushQueueItemText" Color="#000000"/>         <!-- 队列项文字颜色 -->
    <SolidColorBrush x:Key="BrushQueueItemArtist" Color="#000000"/>       <!-- 队列项艺术家文字颜色 -->
    <SolidColorBrush x:Key="BrushQueuePlayingBg" Color="#606060"/>        <!-- 队列当前播放项背景 -->
    <SolidColorBrush x:Key="BrushQueuePlayingText" Color="#000000"/>      <!-- 队列当前播放项文字 -->

    <!-- ============================================================ -->
    <!-- 阴影 -->
    <!-- ============================================================ -->
    <DropShadowEffect x:Key="ShadowSmall" BlurRadius="15" Opacity="0.08" 
                      ShadowDepth="2" Color="#000000"/>
    <DropShadowEffect x:Key="ShadowMedium" BlurRadius="30" Opacity="0.12" 
                      ShadowDepth="5" Color="#000000"/>
    <DropShadowEffect x:Key="ShadowLarge" BlurRadius="50" Opacity="0.15"
                      ShadowDepth="8" Color="#000000"/>

    <!-- 侧栏：从浅灰到纯白的微妙过渡 -->
    <LinearGradientBrush x:Key="BrushGradientSidebar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F5F5F7" Offset="0"/>
        <GradientStop Color="#FFFFFF" Offset="1"/>
    </LinearGradientBrush>

    <!-- 右侧详情面板：保持明亮洁净 -->
    <LinearGradientBrush x:Key="BrushGradientDetail" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F9F9FB" Offset="1"/>
    </LinearGradientBrush>

    <!-- 底部播放栏：使用极浅的灰色营造坚实感 -->
    <LinearGradientBrush x:Key="BrushGradientBar" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFF" Offset="0"/>
        <GradientStop Color="#F2F2F7" Offset="1"/>
    </LinearGradientBrush>

    <!-- ============================================================ -->
    <!-- 转换器 -->
    <!-- ============================================================ -->
    <helpers:DurationConverter x:Key="DurationConverter"/>
    <helpers:BytesToImageConverter x:Key="BytesToImageConverter"/>
    <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <helpers:RecentViewVisibleConverter x:Key="RecentVis"/>
    <helpers:IsCurrentSongConverter x:Key="IsCurrentSong"/>

    <!-- ============================================================ -->
    <!-- 全局隐式样式 —— 自动应用到所有同类型控件，无需显式指定 Style -->
    <!-- ============================================================ -->

    <!-- ============================================================ -->
    <!-- 优化后的现代极简 Button 样式 -->
    <!-- ============================================================ -->
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BrushButtonBg}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="16,8"/> <!-- 增加内边距更显高级 -->
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- 圆角提升至 10px，增加平滑度 -->
                    <Border x:Name="border" 
                            Background="{TemplateBinding Background}"
                            CornerRadius="10" 
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- 悬停时使用 Accent 颜色，但不切换，而是通过视觉反馈 -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushHover}"/>
                        </Trigger>
                        <!-- 增加按下时的反馈 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- 保留你的缩放动画，但缩放比例调微小一点，更符合极简直觉 -->
            <EventTrigger RoutedEvent="Mouse.MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation To="1.02" Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.ScaleX">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation To="1.02" Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.ScaleY">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Mouse.MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation To="1.0" Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.ScaleX"/>
                        <DoubleAnimation To="1.0" Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.ScaleY"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- 播放/暂停按钮：圆形灰色背景 + 图标 -->
    <Style x:Key="PlayPauseButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="12,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse x:Name="BgCircle" Fill="{StaticResource BrushButtonBg}" Width="40" Height="40"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BgCircle" Property="Fill" Value="{StaticResource BrushBorder}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- TextBox：极简白色版 (保持原有逻辑，优化边框交互) -->
    <Style TargetType="TextBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/> <!-- 增加一条极细的底边框 -->
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="2,4"/>
        <Setter Property="CaretBrush" Value="{StaticResource BrushAccent}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
            </Trigger>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource BrushAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="Background" Value="{StaticResource BrushBorder}"/> <!-- 轨道底色改用更淡的分割线色 -->
        <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="20" Background="Transparent"> <!-- 增加热区高度方便点击 -->
                        <Border x:Name="TrackBackground" 
                                Background="{TemplateBinding Background}" 
                                Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="{TemplateBinding Foreground}" Height="4"
                                              BorderThickness="0" Foreground="Transparent"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="14" Height="14" Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <!-- 滑块改为纯色，阴影颜色改为深灰而非红色 -->
                                            <Ellipse Fill="White" Stroke="{TemplateBinding Foreground}" StrokeThickness="1"
                                                     Width="14" Height="14">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect BlurRadius="5" Opacity="0.1" ShadowDepth="1" Color="Black"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Width" Value="4"/> <!-- 进一步收窄 -->
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Cursor="Hand">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBorder"
                                                    Background="{StaticResource BrushTextTertiary}" 
                                                    Opacity="0.4"
                                                    CornerRadius="2" MinHeight="40">
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <!-- 悬停时变宽变深，这样更高级 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource BrushTextSecondary}"/>
                                                    <Setter TargetName="ThumbBorder" Property="Opacity" Value="0.8"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ContextMenu：白色现代卡片风格 -->
    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource BrushBgCard}"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BrushBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <!-- 关键：增加 ShadowMedium 让菜单浮起来 -->
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="12"
                            Effect="{StaticResource ShadowMedium}">
                        <ScrollViewer Margin="0" Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                            <ItemsPresenter Margin="0"/>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Padding" Value="12,8"/>
        <!-- 核心点：必须设置这个，否则子菜单的文字会继承错误的颜色 -->
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8" 
                                Margin="4,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 图标/勾选区 -->
                                <ContentPresenter x:Name="Icon" ContentSource="Icon" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <!-- 文字内容 -->
                                <ContentPresenter Grid.Column="1" 
                                                  ContentSource="Header" 
                                                  RecognizesAccessKey="True" 
                                                  VerticalAlignment="Center"/>
                                <!-- 箭头：如果有子菜单则显示 -->
                                <Path x:Name="RightArrow" Grid.Column="2" 
                                      Data="M0,0 L4,3.5 L0,7" 
                                      Stroke="{TemplateBinding Foreground}" 
                                      StrokeThickness="1" 
                                      Margin="10,0,0,0" 
                                      VerticalAlignment="Center" 
                                      Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <!-- 子菜单容器 -->
                        <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False" 
                               IsOpen="{TemplateBinding IsSubmenuOpen}" PopupAnimation="Fade" Placement="Right">
                            <Border Background="{StaticResource BrushBgCard}" 
                                    BorderBrush="{StaticResource BrushBorder}" 
                                    BorderThickness="1" 
                                    CornerRadius="12" 
                                    Effect="{StaticResource ShadowMedium}"
                                    Padding="4">
                                <ScrollViewer x:Name="SubMenuScrollViewer" Style="{DynamicResource {x:Static GridView.GridViewScrollViewerStyleKey}}">
                                    <ItemsPresenter Grid.IsSharedSizeScope="True"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- 只有有子项时才显示箭头 -->
                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="RightArrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BrushSelection}"/>
                            <!-- 确保高亮时文字依然是深色 -->
                            <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ListBox：保持简洁透明 (无需修改，发送下一段) -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="#E6212121"/> <!-- 深色半透明背景 -->
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 歌曲列表项：现代极简版 (深灰播放 + 浅灰悬停) -->
    <Style x:Key="SongItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="Padding" Value="14,10"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="12" 
                            Margin="6,2">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BrushSelection}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style.Triggers>
            <!-- 1. 悬停状态：显示为浅灰色 -->
            <Trigger Property="IsMouseOver" Value="True">
                <!-- 这里建议使用之前定义的 BrushHover (#00000008) 或 BrushBgSecondary -->
                <Setter Property="Background" Value="{StaticResource BrushHover}"/>
            </Trigger>

            <!-- 2. 正在播放状态：显示为深灰色，且放在最后以覆盖悬停效果 -->
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource IsCurrentSong}">
                        <Binding />
                        <Binding Path="DataContext.CurrentPlayingSong"
                                 RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <!-- 这里的深灰色建议使用 #E5E5E7 或 #D1D1D6 左右的色值 -->
                <Setter Property="Background" Value="#dddddd"/> 
                <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- 频谱控件模板 (逻辑保持简洁，重点在 Canvas 内容) -->
    <Style TargetType="views:SpectrumControl">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="views:SpectrumControl">
                    <!-- 确保频谱不会溢出圆角容器 -->
                    <Border Background="{TemplateBinding Background}" CornerRadius="8" ClipToBounds="True">
                        <Canvas x:Name="PART_Canvas"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 专门给音量条用的样式：取消悬停变色 -->
    <Style x:Key="SliderStyle" TargetType="Slider" BasedOn="{StaticResource {x:Type Slider}}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid Height="20">
                        <Border Background="{StaticResource BrushBorder}" Height="3" CornerRadius="1.5" VerticalAlignment="Center"/>
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="{StaticResource BrushAccent}" Height="3" BorderThickness="0">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <!-- 纯色填充，无任何交互逻辑 -->
                                            <Border Background="{TemplateBinding Background}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="10" Height="10">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Fill="White" Stroke="{StaticResource BrushAccent}" StrokeThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <!-- 此处不添加任何 IsMouseOver 的 Trigger -->
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- 底部导航栏调用 -->
    <!-- 歌名样式 -->
    <Style x:Key="TextSongName" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/> <!-- 超长显示省略号 -->
    </Style>

    <!-- 歌手名样式 -->
    <Style x:Key="TextArtistName" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

</ResourceDictionary>