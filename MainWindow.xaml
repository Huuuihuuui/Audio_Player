<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MusicPlayer.ViewModels"
        xmlns:helpers="clr-namespace:MusicPlayer.Helpers"
        xmlns:views="clr-namespace:MusicPlayer.Views"
        Title="MusicPlayer" Height="650" Width="1050"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BrushBgPrimary}"
        Foreground="{StaticResource BrushTextPrimary}">

    <!-- 数据上下文：MainViewModel 为整个窗口提供数据绑定和命令 -->
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <!-- 三行布局：主内容区(*) / 播放队列(Auto) / 底部播放栏(Auto) -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ====== 第一行：主内容区（左导航 + 右内容） ====== -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====== 左侧导航栏（220px） ====== -->
            <Border Background="{StaticResource BrushGradientSidebar}" Grid.Column="0">
                <StackPanel Margin="16,20">
                    <!-- 应用标题 -->
                    <TextBlock Text="MusicPlayer"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{StaticResource BrushAccent}"
                               Margin="0,0,0,30"/>

                    <!-- 视图导航：全部歌曲 / 收藏歌曲 / 最近播放 -->
                    <TextBlock Text="音乐库" FontSize="14"
                               Foreground="{StaticResource BrushTextSecondary}" Margin="0,8,0,4"/>
                    <ListBox x:Name="NavListBox" BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="NavListBox_SelectionChanged">
                        <ListBoxItem Tag="all" IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8F1;" FontFamily="Segoe MDL2 Assets"
                                           Margin="0,0,8,0" FontSize="16"/>
                                <TextBlock Text="所有歌曲"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="favorites">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xEB51;" FontFamily="Segoe MDL2 Assets"
                                           Margin="0,0,8,0" FontSize="16"/>
                                <TextBlock Text="收藏歌曲"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="recent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets"
                                           Margin="0,0,8,0" FontSize="16"/>
                                <TextBlock Text="最近播放"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <!-- 歌单管理区：标题 + 新建按钮 + 歌单列表 -->
                    <Grid Margin="0,20,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="歌单" FontSize="14"
                                   Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="&#xE710;"
                                FontFamily="Segoe MDL2 Assets"
                                Click="PlaylistCreate_Click"
                                Background="Transparent"
                                Foreground="{StaticResource BrushTextSecondary}"
                                FontSize="14" Padding="4,0"
                                ToolTip="新建歌单"/>
                    </Grid>
                    <ListBox x:Name="PlaylistNavBox" BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding Playlists}"
                             DisplayMemberPath="Name"
                             SelectedItem="{Binding SelectedPlaylist}"
                             SelectionChanged="PlaylistNavBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu x:Name="PlaylistContextMenu">
                                <MenuItem Header="重命名" Click="PlaylistRename_Click"/>
                                <MenuItem Header="删除歌单" Click="PlaylistDelete_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="8" Margin="2,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BrushSelection}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource BrushHover}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- ====== 右侧内容区：歌曲列表 / 分割线 / 详情面板（三栏） ====== -->
            <Grid Grid.Column="1" Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- ====== 中栏左：歌曲列表区 ====== -->
                <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 搜索栏（Segoe MDL2 图标 + TextBox）+ 清空按钮（仅最近播放视图可见） -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="{StaticResource BrushBgCard}" CornerRadius="8" Padding="4,2">
                        <Grid>
                            <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets"
                                       VerticalAlignment="Center" FontSize="16"
                                       Margin="10,0,0,0" Foreground="{StaticResource BrushTextSecondary}"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Foreground="{StaticResource BrushTextPrimary}" FontSize="14"
                                     Padding="36,8" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Content="清空"
                            Command="{Binding ClearPlayHistoryCommand}"
                            Padding="12,6" Margin="8,0,0,0"
                            Visibility="{Binding CurrentView, Converter={StaticResource RecentVis}}"/>
                </Grid>

                <!-- 文件夹管理面板：已添加文件夹列表 + 添加/扫描按钮 -->
                <Border Grid.Row="1" Background="{StaticResource BrushBgCard}"
                        CornerRadius="8" Padding="8,6" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 已添加的文件夹列表 -->
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding WatchedFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource BrushTextSecondary}" FontSize="14"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}"
                                                   Foreground="{StaticResource BrushTextSecondary}" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}"/>
                                        <Button Grid.Column="2" Content="&#xE711;"
                                                FontFamily="Segoe MDL2 Assets"
                                                Command="{Binding DataContext.RemoveWatchedFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{StaticResource BrushAccent}"
                                                Background="Transparent"
                                                Padding="6,2" FontSize="12"
                                                ToolTip="移除此文件夹并清理对应歌曲"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 操作按钮行 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 添加文件夹"
                                    Command="{Binding AddWatchedFolderCommand}"
                                    Margin="0,0,8,0"/>
                            <Button Content="扫描全部"
                                    Command="{Binding ScanFolderCommand}"
                                    Background="{StaticResource BrushAccent}"
                                    Foreground="White"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 歌曲列表：4列布局（标题+艺术家 / 专辑 / 格式 / 时长），使用 SongItemStyle -->
                <ListBox x:Name="SongListBox" Grid.Row="2" BorderThickness="0"
                         MouseDoubleClick="SongList_MouseDoubleClick"
                         Background="Transparent"
                         ItemsSource="{Binding Songs}"
                         SelectedItem="{Binding SelectedSong}"
                         ItemContainerStyle="{StaticResource SongItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu x:Name="SongContextMenu"
                                     Opened="SongContextMenu_Opened">
                            <MenuItem Header="收藏 / 取消收藏"
                                      Command="{Binding ToggleFavoriteCommand}"
                                      CommandParameter="{Binding SelectedSong}"/>
                            <Separator/>
                            <MenuItem x:Name="AddToPlaylistMenu" Header="添加到歌单"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="14"
                                               FontWeight="Medium" Foreground="{StaticResource BrushTextPrimary}"/>
                                    <TextBlock Text="{Binding Artist}" FontSize="12"
                                               Foreground="{StaticResource BrushTextSecondary}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Album}"
                                           FontSize="12" Foreground="{StaticResource BrushTextSecondary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Format}"
                                           FontSize="12" Foreground="{StaticResource BrushTextSecondary}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" FontSize="12"
                                           Text="{Binding DurationSeconds, Converter={StaticResource DurationConverter}}"
                                           Foreground="{StaticResource BrushTextSecondary}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>

                <!-- ====== 中栏中：4px 分割线 ====== -->
                <Border Grid.Column="1" Background="{StaticResource BrushBorder}" Width="1"
                        VerticalAlignment="Stretch" Margin="0,0,0,16" Opacity="0.6"/>

                <!-- ====== 中栏右：歌曲详情面板（280px） ====== -->
                <Border Grid.Column="2" Background="{StaticResource BrushGradientDetail}"
                        CornerRadius="12" Padding="16"
                        VerticalAlignment="Stretch" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 封面图（180×180 + 圆角 12 + 小阴影） -->
                            <Border Width="180" Height="180"
                                    Background="{StaticResource BrushBorder}" CornerRadius="12"
                                    HorizontalAlignment="Center" Margin="0,0,0,12"
                                    Effect="{StaticResource ShadowSmall}">
                                <Image Source="{Binding CoverImageData, Converter={StaticResource BytesToImageConverter}}"
                                       Stretch="Uniform"/>
                            </Border>

                            <!-- 歌曲名称 -->
                            <TextBlock Text="{Binding DetailTitle}"
                                       FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrushTextPrimary}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,4"/>

                            <!-- 艺术家 -->
                            <TextBlock Text="{Binding DetailArtist}"
                                       FontSize="13" Foreground="{StaticResource BrushAccent}"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <!-- 信息分隔线：歌曲名+艺术家 / 元数据信息 -->
                            <Border Background="{StaticResource BrushBorder}" Height="1" Margin="0,0,0,10" Opacity="0.6"/>

                            <!-- 专辑 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="专辑" Foreground="{StaticResource BrushTextTertiary}"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailAlbum}"
                                           Foreground="{StaticResource BrushTextPrimary}" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- 格式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="格式" Foreground="{StaticResource BrushTextTertiary}"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailFormat}"
                                           Foreground="{StaticResource BrushTextPrimary}" FontSize="11"/>
                            </StackPanel>

                            <!-- 音频规格 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="规格" Foreground="{StaticResource BrushTextTertiary}"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailSpecs}"
                                           Foreground="{StaticResource BrushTextPrimary}" FontSize="11"/>
                            </StackPanel>

                            <!-- 歌词分隔线 -->
                            <Border Background="{StaticResource BrushBorder}" Height="1" Margin="0,12,0,8" Opacity="0.6"/>

                            <!-- 歌词区：标题 + ◀▶ 偏移微调按钮 + 行列表（当前行红色加粗） -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="歌词" FontSize="11"
                                           Foreground="{StaticResource BrushTextTertiary}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button x:Name="LyricBackBtn" Content="◀" Click="LyricBackward_Click"
                                            Background="Transparent" Foreground="{StaticResource BrushTextTertiary}"
                                            BorderThickness="0" FontSize="8" Padding="2"
                                            Cursor="Hand"/>
                                    <TextBlock Text="{Binding LyricOffset, StringFormat={}{0:+#0.0;-#0.0;s}}"
                                               FontSize="9" Foreground="{StaticResource BrushTextTertiary}"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <Button x:Name="LyricFwdBtn" Content="▶" Click="LyricForward_Click"
                                            Background="Transparent" Foreground="{StaticResource BrushTextTertiary}"
                                            BorderThickness="0" FontSize="8" Padding="2"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="{StaticResource BrushDarkWell}" CornerRadius="6"
                                    Height="100" Padding="6,4">
                                <ScrollViewer x:Name="LyricsScrollViewer"
                                              VerticalScrollBarVisibility="Hidden"
                                              CanContentScroll="False">
                                    <ItemsControl x:Name="LyricsItemsControl"
                                                  ItemsSource="{Binding LyricsLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="12"
                                                           Margin="0,2"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource BrushTextTertiary}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource BrushAccent}"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- 频谱分隔线 -->
                            <Border Background="{StaticResource BrushBorder}" Height="1" Margin="0,8,0,6" Opacity="0.6"/>

                            <!-- 频谱可视化（64柱，多色渐变频谱） -->
                            <views:SpectrumView x:Name="SpectrumViewControl"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

    <!-- ====== 第二行：播放队列面板（UI 优化版） ====== -->
            <Border Grid.Row="1" Background="{StaticResource BrushBgSecondary}" CornerRadius="12"
                    Margin="24,0,24,12" Effect="{StaticResource ShadowMedium}"
                    Visibility="{Binding QueuePanelVisible, Converter={StaticResource BoolToVis}}">
                <Grid Margin="16,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/> <!-- 高度自适应，不再写死 150 -->
                    </Grid.RowDefinitions>
                    
                    <Grid Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="播放列表" FontSize="14" FontWeight="Bold"
                                    Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PlayQueue.Count, StringFormat='({0} 首)'}"
                                    FontSize="12" Foreground="{StaticResource BrushTextTertiary}"
                                    VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource BrushTextTertiary}"
                                FontSize="14" HorizontalAlignment="Right"
                                Command="{Binding ToggleQueuePanelCommand}"/>
                    </Grid>

                    <ListBox x:Name="QueueListBox" Grid.Row="1" ItemsSource="{Binding PlayQueue}"
                            Background="Transparent" BorderThickness="0"
                            MaxHeight="300" ScrollViewer.VerticalScrollBarVisibility="Auto"
                            MouseDoubleClick="QueueList_MouseDoubleClick"
                            ItemContainerStyle="{StaticResource SongItemStyle}"> <!-- 复用之前写好的悬停样式 -->
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="从列表移除" Click="QueueRemove_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <TextBlock FontSize="12">
                                        <Run Text="{Binding Title}" Foreground="{StaticResource BrushTextPrimary}" FontWeight="Medium"/>
                                        <Run Text=" - " Foreground="{StaticResource BrushTextTertiary}"/>
                                        <Run Text="{Binding Artist}" Foreground="{StaticResource BrushTextTertiary}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- ====== 第三行：底部播放栏 (重构优化版) ====== -->
            <Border Grid.Row="2" Background="{StaticResource BrushGradientBar}" Padding="20,10" BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <!-- 左侧：歌曲信息 (由 250 缩小至 220，腾出空间给进度条) -->
                        <ColumnDefinition Width="220"/>
                        <!-- 中间：核心控制区 (拉长) -->
                        <ColumnDefinition Width="*"/>
                        <!-- 右侧：音量与列表 (由 200 增加至 220，容纳列表按钮) -->
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0">
                        <!-- 直接从歌曲对象中取 Title -->
                        <TextBlock Text="{Binding CurrentPlayingSong.Title, FallbackValue='未在播放'}" 
                                Style="{StaticResource TextSongName}"/>
                        
                        <!-- 直接从歌曲对象中取 Artist -->
                        <TextBlock Text="{Binding CurrentPlayingSong.Artist, FallbackValue='未知艺术家'}" 
                                Style="{StaticResource TextArtistName}"/>
                    </StackPanel>

                    <!-- 2. 中间：控制按钮 + 进度条 (均匀排布，进度条最长化) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- 按钮行：去背景、均匀间距 -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                            <Button Content="{Binding PlayModeText}" Command="{Binding CyclePlayModeCommand}"
                                    Background="Transparent" Foreground="{StaticResource BrushTextSecondary}" 
                                    FontSize="14" Margin="10,0" ToolTip="切换播放模式"/>
                            
                            <Button Content="&#xE892;" FontFamily="Segoe MDL2 Assets" Command="{Binding PreviousCommand}"
                                    Background="Transparent" Foreground="{StaticResource BrushTextPrimary}" 
                                    FontSize="18" Margin="10,0" Padding="5"/>
                            
                            <!-- 播放按钮：应用无背景样式 -->
                            <Button Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}"
                                    Style="{StaticResource PlayPauseButtonStyle}"/>
                            
                            <Button Content="&#xE893;" FontFamily="Segoe MDL2 Assets" Command="{Binding NextCommand}"
                                    Background="Transparent" Foreground="{StaticResource BrushTextPrimary}" 
                                    FontSize="18" Margin="10,0" Padding="5"/>

                            <Button Content="&#xE71A;" FontFamily="Segoe MDL2 Assets" Command="{Binding StopCommand}"
                                    Background="Transparent" Foreground="{StaticResource BrushTextSecondary}" 
                                    FontSize="14" Margin="10,0" ToolTip="停止"/>
                        </StackPanel>

                        <!-- 进度条行：拉满 -->
                        <Grid Height="24" Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding CurrentPositionText}"
                                    FontSize="10" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                            
                            <Slider Grid.Column="1" Margin="10,0" VerticalAlignment="Center"
                                    Value="{Binding ProgressPercent, Mode=TwoWay}"
                                    Minimum="0" Maximum="100" IsMoveToPointEnabled="True"/>
                            
                            <!-- 找到右侧显示总时间的 TextBlock -->
                            <TextBlock Grid.Column="2" Text="{Binding TotalDurationText}"
                                    FontSize="10" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- 3. 右侧：音量条 + 播放列表按钮 (整合) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="&#xE995;" FontFamily="Segoe MDL2 Assets"
                                FontSize="14" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                        
                        <!-- 应用 VolumeSliderStyle：无变色 -->
                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="1" Width="100" Margin="10,0"
                                Style="{StaticResource VolumeSliderStyle}" VerticalAlignment="Center"/>
                        
                        <!-- 列表按钮挪位至此 -->
                        <Button Content="&#xE700;" FontFamily="Segoe MDL2 Assets"
                                Command="{Binding ToggleQueuePanelCommand}"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource BrushTextSecondary}" FontSize="18"
                                Margin="10,0,0,0" Padding="4" ToolTip="播放列表"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
</Window>
