<Window x:Class="MusicPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MusicPlayer.ViewModels"
        xmlns:helpers="clr-namespace:MusicPlayer.Helpers"
        xmlns:views="clr-namespace:MusicPlayer.Views"
        Title="MusicPlayer" Height="650" Width="1050"
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Foreground="#e0e0e0">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <helpers:DurationConverter x:Key="DurationConverter"/>
        <helpers:BytesToImageConverter x:Key="BytesToImageConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:RecentViewVisibleConverter x:Key="RecentVis"/>
        <helpers:IsCurrentSongConverter x:Key="IsCurrentSong"/>

        <!-- 频谱控件默认模板 -->
        <Style TargetType="views:SpectrumControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="views:SpectrumControl">
                        <Canvas x:Name="PART_Canvas" ClipToBounds="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 颜色 -->
        <SolidColorBrush x:Key="BgPrimary" Color="#1a1a2e"/>
        <SolidColorBrush x:Key="BgSecondary" Color="#16213e"/>
        <SolidColorBrush x:Key="BgCard" Color="#1f2b47"/>
        <SolidColorBrush x:Key="AccentColor" Color="#e94560"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#e0e0e0"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#a0a0b8"/>

        <!-- 列表项样式 -->
        <Style x:Key="SongItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6" Margin="2,1">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#e9456030"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#ffffff10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IsCurrentSong}">
                            <Binding />
                            <Binding Path="DataContext.CurrentPlayingSong"
                                     RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#e9456040"/>
                    <Setter Property="Foreground" Value="#ffffff"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主内容区 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Background="#16213e" Grid.Column="0">
                <StackPanel Margin="16,20">
                    <TextBlock Text="MusicPlayer"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#e94560"
                               Margin="0,0,0,30"/>

                    <TextBlock Text="音乐库" FontSize="14"
                               Foreground="#a0a0b8" Margin="0,8,0,4"/>
                    <ListBox x:Name="NavListBox" BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="NavListBox_SelectionChanged">
                        <ListBoxItem Tag="all" IsSelected="True">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="♪" Margin="0,0,8,0"/> <TextBlock Text="所有歌曲"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="favorites">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="♥" Margin="0,0,8,0"/> <TextBlock Text="收藏歌曲"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem Tag="recent">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏱" Margin="0,0,8,0"/> <TextBlock Text="最近播放"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <Grid Margin="0,20,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="歌单" FontSize="14"
                                   Foreground="#a0a0b8" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="+"
                                Click="PlaylistCreate_Click"
                                Background="Transparent" Foreground="#a0a0b8"
                                BorderThickness="0" FontSize="14" Padding="4,0"
                                Cursor="Hand" ToolTip="新建歌单"/>
                    </Grid>
                    <ListBox x:Name="PlaylistNavBox" BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding Playlists}"
                             DisplayMemberPath="Name"
                             SelectedItem="{Binding SelectedPlaylist}"
                             SelectionChanged="PlaylistNavBox_SelectionChanged">
                        <ListBox.ContextMenu>
                            <ContextMenu x:Name="PlaylistContextMenu">
                                <MenuItem Header="重命名" Click="PlaylistRename_Click"/>
                                <MenuItem Header="删除歌单" Click="PlaylistDelete_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#e0e0e0"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="{TemplateBinding Padding}"
                                                    CornerRadius="6" Margin="2,1">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="#e9456030"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#ffffff10"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- 右侧内容区（左右分栏） -->
            <Grid Grid.Column="1" Margin="24,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：歌曲列表 -->
                <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 搜索栏 + 清空按钮 -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#1f2b47" CornerRadius="8" Padding="4,2">
                        <Grid>
                            <TextBlock Text="🔍" VerticalAlignment="Center"
                                       Margin="10,0,0,0" Foreground="#a0a0b8"/>
                            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#e0e0e0" FontSize="14"
                                     Padding="36,8" VerticalAlignment="Center">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </Grid>
                    </Border>
                    <Button Grid.Column="1" Content="清空"
                            Command="{Binding ClearPlayHistoryCommand}"
                            Background="#3a3f5c" Foreground="#e0e0e0"
                            BorderThickness="0" Padding="12,6" Margin="8,0,0,0"
                            Cursor="Hand" FontSize="12"
                            Visibility="{Binding CurrentView, Converter={StaticResource RecentVis}}">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="4"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <!-- 文件夹管理 -->
                <Border Grid.Row="1" Background="#1f2b47"
                        CornerRadius="8" Padding="8,6" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 已添加的文件夹列表 -->
                        <ItemsControl Grid.Row="0" ItemsSource="{Binding WatchedFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="📁" VerticalAlignment="Center"
                                                   Foreground="#a0a0b8" FontSize="11"
                                                   Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding}"
                                                   Foreground="#a0a0b8" FontSize="11"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}"/>
                                        <Button Grid.Column="2" Content="✕"
                                                Command="{Binding DataContext.RemoveWatchedFolderCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="#e94560" Background="Transparent"
                                                BorderThickness="0" Padding="6,2"
                                                Cursor="Hand" FontSize="10"
                                                ToolTip="移除此文件夹并清理对应歌曲"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 操作按钮行 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="+ 添加文件夹"
                                    Command="{Binding AddWatchedFolderCommand}"
                                    Background="#3a3f5c" Foreground="#e0e0e0"
                                    BorderThickness="0" Padding="14,6"
                                    Cursor="Hand" FontSize="12" Margin="0,0,8,0">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                            <Button Content="扫描全部"
                                    Command="{Binding ScanFolderCommand}"
                                    Background="#e94560" Foreground="White"
                                    BorderThickness="0" Padding="16,6"
                                    Cursor="Hand" FontSize="12"
                                    FontWeight="Medium">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="4"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 歌曲列表 -->
                <ListBox x:Name="SongListBox" Grid.Row="2" BorderThickness="0"
                         MouseDoubleClick="SongList_MouseDoubleClick"
                         Background="Transparent"
                         ItemsSource="{Binding Songs}"
                         SelectedItem="{Binding SelectedSong}"
                         ItemContainerStyle="{StaticResource SongItemStyle}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ContextMenu>
                        <ContextMenu x:Name="SongContextMenu"
                                     Opened="SongContextMenu_Opened">
                            <MenuItem Header="收藏 / 取消收藏"
                                      Command="{Binding ToggleFavoriteCommand}"
                                      CommandParameter="{Binding SelectedSong}"/>
                            <Separator/>
                            <MenuItem x:Name="AddToPlaylistMenu" Header="添加到歌单"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontSize="14"
                                               FontWeight="Medium" Foreground="#e0e0e0"/>
                                    <TextBlock Text="{Binding Artist}" FontSize="12"
                                               Foreground="#a0a0b8" Margin="0,2,0,0"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding Album}"
                                           FontSize="12" Foreground="#a0a0b8"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Format}"
                                           FontSize="12" Foreground="#a0a0b8"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" FontSize="12"
                                           Text="{Binding DurationSeconds, Converter={StaticResource DurationConverter}}"
                                           Foreground="#a0a0b8"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                </Grid>

                <!-- 分隔线 -->
                <Border Grid.Column="1" Background="#2a2a4a" Width="1"
                        VerticalAlignment="Stretch" Margin="0,0,0,16"/>

                <!-- 右侧：歌曲详情面板 -->
                <Border Grid.Column="2" Background="#1f2b47"
                        CornerRadius="12" Padding="16"
                        VerticalAlignment="Stretch" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- 封面图片 -->
                            <Border Width="180" Height="180"
                                    Background="#2a2a4a" CornerRadius="8"
                                    HorizontalAlignment="Center" Margin="0,0,0,12">
                                <Image Source="{Binding CoverImageData, Converter={StaticResource BytesToImageConverter}}"
                                       Stretch="Uniform"/>
                            </Border>

                            <!-- 歌曲名称 -->
                            <TextBlock Text="{Binding DetailTitle}"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#e0e0e0"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,4"/>

                            <!-- 艺术家 -->
                            <TextBlock Text="{Binding DetailArtist}"
                                       FontSize="13" Foreground="#e94560"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>

                            <!-- 信息分隔线 -->
                            <Border Background="#2a2a4a" Height="1" Margin="0,0,0,10"/>

                            <!-- 专辑 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="专辑" Foreground="#8888a0"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailAlbum}"
                                           Foreground="#e0e0e0" FontSize="11"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- 格式 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="格式" Foreground="#8888a0"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailFormat}"
                                           Foreground="#e0e0e0" FontSize="11"/>
                            </StackPanel>

                            <!-- 音频规格 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="规格" Foreground="#8888a0"
                                           FontSize="11" Width="50"/>
                                <TextBlock Text="{Binding DetailSpecs}"
                                           Foreground="#e0e0e0" FontSize="11"/>
                            </StackPanel>

                            <!-- 歌词分隔线 -->
                            <Border Background="#2a2a4a" Height="1"
                                    Margin="0,12,0,8"/>

                            <!-- 歌词显示区域 -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="歌词" FontSize="11"
                                           Foreground="#8888a0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <Button x:Name="LyricBackBtn" Content="◀" Click="LyricBackward_Click"
                                            Background="Transparent" Foreground="#8888a0"
                                            BorderThickness="0" FontSize="8" Padding="2"
                                            Cursor="Hand"/>
                                    <TextBlock Text="{Binding LyricOffset, StringFormat={}{0:+#0.0;-#0.0;s}}"
                                               FontSize="9" Foreground="#8888a0"
                                               VerticalAlignment="Center" Margin="2,0"/>
                                    <Button x:Name="LyricFwdBtn" Content="▶" Click="LyricForward_Click"
                                            Background="Transparent" Foreground="#8888a0"
                                            BorderThickness="0" FontSize="8" Padding="2"
                                            Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                            <Border Background="#0a1628" CornerRadius="4"
                                    Height="100" Padding="6,4">
                                <ScrollViewer x:Name="LyricsScrollViewer"
                                              VerticalScrollBarVisibility="Hidden"
                                              CanContentScroll="False">
                                    <ItemsControl x:Name="LyricsItemsControl"
                                                  ItemsSource="{Binding LyricsLines}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           FontSize="11"
                                                           Margin="0,2"
                                                           TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#8888a0"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                                    <Setter Property="Foreground" Value="#e94560"/>
                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                    <Setter Property="FontSize" Value="12"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- 频谱分隔线 -->
                            <Border Background="#2a2a4a" Height="1"
                                    Margin="0,8,0,6"/>

                            <!-- 频谱可视化 -->
                            <views:SpectrumView x:Name="SpectrumViewControl"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- 播放队列弹出面板 -->
        <Border Grid.Row="1" Background="#16213e" CornerRadius="8"
                Margin="24,0,24,8"
                Visibility="{Binding QueuePanelVisible, Converter={StaticResource BoolToVis}}">
            <Grid Margin="12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="播放列表" FontSize="13" FontWeight="Bold"
                               Foreground="#e0e0e0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding PlayQueue.Count, StringFormat='({0} 首)'}"
                               FontSize="11" Foreground="#8888a0"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                    <Button Content="✕" Background="Transparent"
                            Foreground="#8888a0" BorderThickness="0"
                            Cursor="Hand" FontSize="14" Padding="6,2"
                            HorizontalAlignment="Right"
                            Command="{Binding ToggleQueuePanelCommand}"/>
                </StackPanel>
                <ListBox x:Name="QueueListBox" Grid.Row="1" ItemsSource="{Binding PlayQueue}"
                         Background="Transparent" BorderThickness="0"
                         MouseDoubleClick="QueueList_MouseDoubleClick">
                    <ListBox.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="从列表移除" Click="QueueRemove_Click"/>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#e0e0e0"/>
                            <Setter Property="Padding" Value="8,4"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="12" Foreground="#e0e0e0"
                                       TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding Title}"/>
                                <Run Text=" - " Foreground="#8888a0"/>
                                <Run Text="{Binding Artist}" Foreground="#8888a0"/>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 底部播放栏 -->
        <Border Grid.Row="2" Background="#0f3460" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- 当前歌曲信息 + 播放列表按钮 -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Orientation="Horizontal">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentSongTitle}"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#e0e0e0"
                                   TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                        <TextBlock Text="{Binding CurrentLyricLine}"
                                   FontSize="11" Foreground="#a0a0b8"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0" MaxWidth="180"/>
                    </StackPanel>
                    <Button Content="≡" Command="{Binding ToggleQueuePanelCommand}"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                            Foreground="#a0a0b8" FontSize="14"
                            Margin="4,0,0,0" ToolTip="播放列表"/>
                </StackPanel>

                <!-- 播放控制 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="⏮" Command="{Binding PreviousCommand}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#e0e0e0" FontSize="16"/>
                        <Button Content="{Binding PlayPauseText}" Command="{Binding PlayPauseCommand}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Width="40" FontSize="18" Foreground="#e94560"
                                Margin="8,0"/>
                        <Button Content="⏹" Command="{Binding StopCommand}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#e0e0e0" FontSize="16"/>
                        <Button Content="⏭" Command="{Binding NextCommand}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#e0e0e0" FontSize="16"/>
                        <Button Content="{Binding PlayModeText}" Command="{Binding CyclePlayModeCommand}"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#e0e0e0" FontSize="12"
                                Margin="4,0,0,0" ToolTip="切换播放模式"/>
                    </StackPanel>
                    <!-- 进度条（Slider 伪装成进度条，支持点击跳转+拖拽） -->
                    <Grid Margin="0,6,0,0" Height="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding CurrentPositionText}"
                                   FontSize="10" Foreground="#a0a0b8" VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Value="{Binding ProgressPercent, Mode=TwoWay}"
                                Minimum="0" Maximum="100"
                                Height="16" Margin="6,0"
                                VerticalAlignment="Center"
                                IsMoveToPointEnabled="True">
                            <Slider.Style>
                                <Style TargetType="Slider">
                                    <Setter Property="Background" Value="#16213e"/>
                                    <Setter Property="Foreground" Value="#e94560"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Slider">
                                                <Track x:Name="PART_Track">
                                                    <Track.DecreaseRepeatButton>
                                                        <RepeatButton Background="#e94560" BorderThickness="0"
                                                                      Foreground="Transparent"/>
                                                    </Track.DecreaseRepeatButton>
                                                    <Track.IncreaseRepeatButton>
                                                        <RepeatButton Background="#16213e"/>
                                                    </Track.IncreaseRepeatButton>
                                                    <Track.Thumb>
                                                        <Thumb Width="12" Height="12" Cursor="Hand">
                                                            <Thumb.Template>
                                                                <ControlTemplate TargetType="Thumb">
                                                                    <Ellipse Fill="#e94560" Width="12" Height="12"/>
                                                                </ControlTemplate>
                                                            </Thumb.Template>
                                                        </Thumb>
                                                    </Track.Thumb>
                                                </Track>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Slider.Style>
                        </Slider>
                        <TextBlock Grid.Column="2" Text=""
                                   FontSize="10" Foreground="#a0a0b8" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <!-- 音量 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="🔈" FontSize="14" Foreground="#a0a0b8"/>
                    <Slider Value="{Binding Volume}" Minimum="0" Maximum="1"
                            Width="100" Margin="8,0"
                            Foreground="#e94560"
                            Background="#16213e"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
